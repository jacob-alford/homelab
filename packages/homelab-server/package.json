{
  "name": "homelab-server",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Effect-ts Bun HTTP Server implementation for homelab services",
  "scripts": {
    "circular": "yarn madge --circular ./src/api.ts",
    "dev": "tsx --env-file=.env --watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "rolldown -c",
    "serve": "dotenvx run -f .env -- node ./dist/main.js",
    "lint": "eslint src",
    "typecheck": "node ../../.yarn/sdks/typescript/bin/tsc -b tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:staged": "vitest related --run"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "@effect/cluster": "^0.56.x",
    "@effect/experimental": "^0.58.x",
    "@effect/platform": "^0.94.x",
    "@effect/platform-node": "^0.104.x",
    "@effect/rpc": "^0.73.x",
    "@effect/sql": "^0.49.x",
    "@effect/workflow": "^0.16.x",
    "effect": "^3.x",
    "homelab-api": "workspace:*",
    "homelab-shared": "workspace:*",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.27.x",
    "@types/node": "^24",
    "jose": "^6.x",
    "madge": "^8.0.0",
    "rolldown": "^1.0.0-rc.7",
    "vitest": "^3.x"
  }
}
