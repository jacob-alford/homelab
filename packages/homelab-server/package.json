{
  "name": "homelab-server",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Effect-ts Bun HTTP Server implementation for homelab services",
  "scripts": {
    "circular": "yarn madge --circular ./src/api.ts",
    "dev": "tsx --env-file=.env-local --watch src/main.ts",
    "build": "rolldown -c",
    "serve": "dotenvx run -f .env-local -- node ./dist/main.js",
    "lint": "eslint src",
    "typecheck": "tsc -b tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:staged": "vitest related --run"
  },
  "dependencies": {
    "@effect/cluster": "^0.59.x",
    "@effect/experimental": "^0.60.x",
    "@effect/opentelemetry": "^0.63.x",
    "@effect/platform": "^0.96.x",
    "@effect/platform-node": "^0.107.x",
    "@effect/rpc": "^0.75.x",
    "@effect/sql": "^0.51.x",
    "@effect/workflow": "^0.18.x",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.220.x",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/sdk-trace-web": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.41.x",
    "bufferutil": "^4.1.0",
    "effect": "^3.21.x",
    "homelab-api": "workspace:*",
    "homelab-services": "workspace:*",
    "homelab-services-node": "workspace:*",
    "homelab-shared": "workspace:*",
    "ts-pattern": "^5.9.0",
    "tsx": "^4.21.0",
    "utf-8-validate": "^6.0.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "@effect/vitest": "^0.29.x",
    "@types/node": "^24",
    "jose": "^6.x",
    "madge": "^8.0.0",
    "rolldown": "^1.0.0-rc.7",
    "vitest": "^3.x"
  }
}
