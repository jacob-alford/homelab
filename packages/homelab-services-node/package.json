{
  "name": "homelab-services-node",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Node.js service layer implementations for homelab",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./test-utils": {
      "import": "./test-utils/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint src test test-utils",
    "typecheck": "tsc -b tsconfig.json --noEmit",
    "test": "vitest run",
    "circular": "yarn madge --circular ./src/index.ts",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@effect/cluster": "^0.59.x",
    "@effect/experimental": "^0.60.x",
    "@effect/platform": "^0.96.x",
    "@effect/platform-node": "^0.107.x",
    "@effect/rpc": "^0.75.x",
    "@effect/sql": "^0.51.x",
    "@effect/workflow": "^0.18.x",
    "bufferutil": "^4.1.0",
    "effect": "^3.21.x",
    "homelab-data": "workspace:*",
    "homelab-services": "workspace:*",
    "homelab-shared": "workspace:*",
    "jose": "^6.2.1",
    "utf-8-validate": "^6.0.6"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.x",
    "@types/node": "^24",
    "fast-xml-parser": "^5.5.11",
    "madge": "^8.0.0",
    "type-fest": "^4.x",
    "vitest": "^3.x"
  }
}
