{
  "name": "homelab-api",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Effect-ts Bun HTTP Server / API definitions for homelab services",
  "repository": {
    "type": "git",
    "url": "<PLACEHOLDER>",
    "directory": "packages/homelab-api"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "circular": "yarn madge --circular ./src/index.ts",
    "codegen": "build-utils prepare-v2",
    "lint": "eslint src",
    "typecheck": "node ../../.yarn/sdks/typescript/bin/tsc -b tsconfig.json --noEmit",
    "test:watch": "vitest watch",
    "test": "vitest run --pass-with-no-tests ",
    "test:staged": "vitest related --pass-with-no-tests --run",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect/platform": "^0.94.x",
    "effect": "^3.x",
    "homelab-services": "workspace:*",
    "homelab-shared": "workspace:*"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  },
  "devDependencies": {
    "@effect/vitest": "^0.27.x",
    "@types/node": "^24",
    "@vitest/coverage-v8": "3.2.4",
    "fast-xml-parser": "^5.5.11",
    "madge": "^8.x",
    "vitest": "^3.x"
  }
}
